# Shopify CLI / Admin API credentials
# Copy this file to .env and fill in your values.
# Run `shopify auth login --store <your-store>.myshopify.com` to authenticate via browser.

# Your store's .myshopify.com domain (e.g. my-store.myshopify.com)
SHOPIFY_STORE=

# For headless / CI environments: a long-lived Partners API token.
# Generate one at https://partners.shopify.com/organizations → Settings → Partner API clients.
# Leave blank if you authenticate interactively via `shopify auth login`.
SHOPIFY_CLI_PARTNERS_TOKEN=

# Admin API access token for a custom app on your store.
# Create one at Admin → Settings → Apps and sales channels → Develop apps.
SHOPIFY_ACCESS_TOKEN=
